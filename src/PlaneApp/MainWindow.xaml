<Window x:Class="PlaneApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление самолётами" Height="600" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Количество самолётов:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox x:Name="TxtCount" Width="100" Margin="0,0,10,0"/>
            <Button Content="Задать" Click="BtnSetCount_Click" Padding="10,5"/>
        </StackPanel>

        <StackPanel x:Name="InputPanel" Grid.Row="1" Margin="0,0,0,10" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Модель" FontWeight="Bold"/>
                <TextBlock Grid.Column="1" Text="Дальность (км)" FontWeight="Bold"/>
                <TextBlock Grid.Column="2" Text="Скорость (км/ч)" FontWeight="Bold"/>
            </Grid>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="InputsPanel"/>
            </ScrollViewer>
            <Button Content="Ввести данные" Click="BtnEnterData_Click" Margin="0,10,0,0" Padding="10,5"/>
        </StackPanel>

        <TabControl Grid.Row="2">
            <TabItem Header="Неотсортированный">
                <ListBox x:Name="LbUnsorted" Height="200"/>
            </TabItem>
            <TabItem Header="Отсортированный" Height="22" Margin="-2,0,-2,0" VerticalAlignment="Bottom">
                <ListBox x:Name="LbSorted" Height="200"/>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="3" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,10,0,0">
            <Button Content="Сортировать" Click="BtnSort_Click" Padding="10,5" Margin="0,0,10,0"/>
            <Button Content="Сохранить в файл" Click="BtnSave_Click" Padding="10,5"/>
        </StackPanel>
    </Grid>
</Window>